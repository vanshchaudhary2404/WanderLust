<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>wanderlust</title>
</head>
<body>
  <h3>Listing Details:</h3>
  <ul>
    <li><%= listing.title %></li>
    <li><%= listing.description %></li>
    <li> &#8377;<%= listing.price.toLocaleString("en-IN") %></li>
    <!-- listing.price behave like a string  so to make it use as number we use Number(listing.price).toLocaleString -->
     <!-- <li> &#8377;<%= Number(listing.price).toLocaleString("en-IN") %></li> -->
    <li><%= listing.location %></li>
    <li><%= listing.country %></li>
  </ul>
  <a href="/listings/<%= listing._id %>/edit">Edit this listing</a>
  <br> <br>
  <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
    <button>Delete the listing</button>
  </form>
</body>
</html>